generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleKind {
  CAR
  LTRUCK
  TRUCK
  THEAD
  TCHASS
  TDOLLY
}

enum TireStatus {
  NEW
  ATTACHED
  DETACHED
  IN_REPAIR
  RETIRED
}

model Vehicle {
  id              String       @id
  kind            VehicleKind
  brand           String
  model           String?
  imageUrl        String?       @db.Text
  modelYear       String?
  plateNo         String?
  frameNo         String?       @unique
  nbWheels        Int
  manageTire      Boolean      @default(true)
  status          String       @default("ACTIVE")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tires           Tire[]
  mobilityLogs    MobilityLog[]

  // References for Trail Setups
  asHead          TrailSetup[] @relation("SetupHead")
  trailTrailers   TrailTrailer[]
}

enum TrailType {
  SINGLE_TRAILER
  DOUBLE_TRAILER
}

model TrailSetup {
  id              String         @id
  type            TrailType
  headId          String
  head            Vehicle        @relation("SetupHead", fields: [headId], references: [id])
  trailers        TrailTrailer[]
  totalWheels     Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model TrailTrailer {
  id              String      @id @default(cuid())
  setupId         String
  setup           TrailSetup  @relation(fields: [setupId], references: [id], onDelete: Cascade)
  trailerId       String
  trailer         Vehicle     @relation(fields: [trailerId], references: [id])
  order           Int         // e.g., 1 for first trailer, 2 for dolly, 3 for second trailer
}

model Tire {
  id                String       @id
  serialNo          String       @unique
  brand             String
  size              String
  status            TireStatus   @default(NEW)
  mileage           Float        @default(0.0)
  provisioningDate  DateTime
  attachedToId      String?
  attachedTo        Vehicle?     @relation(fields: [attachedToId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  logs              TireLog[]
}

model TireLog {
  id              String      @id @default(cuid())
  tireId          String
  tire            Tire        @relation(fields: [tireId], references: [id], onDelete: Cascade)
  activity        TireStatus  // State change (e.g. ATTACHED, IN_REPAIR)
  vehicleId       String?     // The unit it was attached to (or detached from)
  unitMileage     Float?      // Mileage of the unit at the time of activity
  timestamp       DateTime    @default(now())
}

model MobilityLog {
  id              String      @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude        Float
  longitude       Float
  speed           Float
  distance        Float       @default(0) // Distance covered in this log segment
  timestamp       DateTime    @default(now())
}
